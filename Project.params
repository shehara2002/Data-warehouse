      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{47C996D2-5549-4D7E-8C87-8B3541BDA850}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Execute SQL Task"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{24360F60-2DB7-46DC-B767-79DC0003E374}"
          SQLTask:SqlStatementSource="DECLARE @StartDate DATE = '2000-01-01'&#xA;DECLARE @EndDate   DATE = '2030-12-31'&#xA;DECLARE @Date      DATE = @StartDate&#xA;&#xA;WHILE @Date &lt;= @EndDate&#xA;BEGIN&#xA;    INSERT INTO DIM_Date (&#xA;        Date_SK,&#xA;        Full_Date,&#xA;        Day,&#xA;        Month,&#xA;        Month_Name,&#xA;        Quarter,&#xA;        Year,&#xA;        Weekday_Name&#xA;    )&#xA;    VALUES (&#xA;        -- Date_SK format: YYYYMMDD e.g. 20240101&#xA;        CONVERT(INT, FORMAT(@Date, 'yyyyMMdd')),&#xA;        @Date,&#xA;        DAY(@Date),&#xA;        MONTH(@Date),&#xA;        DATENAME(MONTH, @Date),&#xA;        DATEPART(QUARTER, @Date),&#xA;        YEAR(@Date),&#xA;        DATENAME(WEEKDAY, @Date)&#xA;    )&#xA;&#xA;    SET @Date = DATEADD(DAY, 1, @Date)&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
