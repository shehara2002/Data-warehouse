            <component
              refId="Package\Load_FACT_Order_Items\OLE DB Source"
              componentClassID="Microsoft.OLEDBSource"
              contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
              description="OLE DB Source"
              name="OLE DB Source"
              usesDispositions="true"
              version="7">
              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset"></property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    -- Order &amp; Item (Degenerate Dimensions + Keys)
    o.Order_Id,
    oi.Order_Item_ID,
    o.Order_Status,
    o.Order_Purchase_Timestamp,
    o.Order_Approved_At,
    o.Order_Delivered_Carrier_Date,
    o.Order_Delivered_Customer_Date,
    o.Order_Estimated_Delivery_Date,
    oi.shipping_limit_date,

    -- Measures
    oi.Price,
    oi.Freight_Value,
    p.Payment_Value,

    -- Customer lookup key
    o.Customer_Trx_ID                  AS Customer_Trx_ID,

    -- Product lookup key
    oi.Product_ID                  AS Product_ID,

    -- Seller lookup key
    oi.Seller_ID                   AS Seller_ID,

    -- Payment lookup keys
    p.payment_sequential           AS Payment_Sequential,
    p.payment_type                 AS Payment_Type,
    p.payment_installments         AS Payment_Installments,

    -- Review lookup key
    r.review_id                    AS Review_ID,

    -- Date SK source column (used in Derived Column step)
    CAST(
        CONVERT(VARCHAR(8), o.Order_Purchase_Timestamp, 112)
    AS INT)                        AS Date_SK

FROM
    stg_Orders                  o

-- Order Items (one row per item per order)
INNER JOIN stg_Order_Item      oi  ON o.Order_Id         = oi.order_id

-- Payment (match on order + sequential to avoid fan-out)
LEFT JOIN stg_order_payment    p   ON o.Order_Id         = p.order_id
                                   AND oi.Order_Item_ID   = p.Payment_Sequential

-- Review (one review per order)
LEFT JOIN stg_Reviews     r   ON o.Order_Id         = r.order_id

WHERE
    o.Order_Status IS NOT NULL</property>
